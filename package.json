{
  "name": "telegram-monthly-sender",
  "version": "1.0.0",
  "description": "Express TypeScript backend that sends a monthly Telegram channel message",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "node-cron": "^4.2.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.23",
    "@types/node": "^24.5.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.2"
  }
}
